---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = Object.values(import.meta.glob('./blog/**/*.mdx', { eager: true }))
  .filter(item => 'date' in item.frontmatter);

posts.sort(
  (a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);

const formatDate = (dateString: string) => {
  const d = new Date(dateString);
  return new Intl.DateTimeFormat("en", {
    day: "2-digit",
    month: "short",
    year: "numeric"
  }).format(d);
};
---

<BaseLayout title="Blog">

<h1>Blog</h1>

<ul class="posts">
  {posts.map((post: any) => (
    <li class="post">
      <div class="date-squircle">{formatDate(post.frontmatter.date)}</div>

      <div class="info">
        <a class="title" href={post.url}>
          {post.frontmatter.title}
        </a>
        {post.frontmatter.description && (
          <p class="description">{post.frontmatter.description}</p>
        )}
      </div>
    </li>
  ))}
</ul>

<style>
.posts {
  list-style: none;
  padding: 0;
  margin: 2rem 0;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.post {
  display: flex;
  align-items: center;
  gap: 1rem;
}

/* Date squircle */
.date-squircle {
  display: flex;
  align-items: center;
  justify-content: center;

  min-width: 72px; /* enough width to fit most dates on a single line */
  height: 32px;    /* single line tall */

  padding: 0 0.6rem;
  font-size: 0.8rem;
  font-weight: 600;
  color: white;    /* readable on green */

  background: #3DA542;
  border-radius: 12px; /* squircle shape */

  flex-shrink: 0;
  text-align: center;
  white-space: nowrap;
}

/* Post content */
.info {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 1.1rem;
  font-weight: 600;
  color: #1f2933;
  text-decoration: none;
  line-height: 1.35;
}

.title:hover {
  color: var(--link-hover);
  text-decoration: underline;
}

.description {
  margin-top: 0.25rem;
  font-size: 0.9rem;
  color: #64748b;
}

/* Mobile adjustments */
@media (max-width: 640px) {
  .date-squircle {
    min-width: 60px;
    height: 28px;
    font-size: 0.75rem;
  }
  .title {
    font-size: 1rem;
  }
}
</style>

</BaseLayout>
