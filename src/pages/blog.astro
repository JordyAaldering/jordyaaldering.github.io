---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import TimelineItem from '../components/TimelineItem.astro';

const posts = Object.values(import.meta.glob('./blog/**/*.mdx', { eager: true }))
  .filter(item => 'date' in item.frontmatter);

posts.sort(
  (a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);

const formatDate = (dateString: string) => {
  const d = new Date(dateString);
  return new Intl.DateTimeFormat("en", {
    day: "2-digit",
    month: "short",
    year: "numeric"
  }).format(d);
};
---

<BaseLayout title="Blog">

<h1>Blog</h1>

<Timeline>
  {posts.map((post: any) => (
    <TimelineItem squircle={formatDate(post.frontmatter.date)}>
      <a class="title" href={post.url}>{post.frontmatter.title}</a>
      {post.frontmatter.description && (
        <p class="description">{post.frontmatter.description}</p>
      )}
    </TimelineItem>
  ))}
</Timeline>

<style>
.title {
  font-size: 1.1rem;
  font-weight: 600;
  color: #1f2933;
  text-decoration: none;
  line-height: 1.35;
}

.title:hover {
  color: var(--link-hover);
  text-decoration: underline;
}

.description {
  margin-top: 0.25rem;
  font-size: 0.9rem;
  color: #64748b;
}

/* Mobile adjustments */
@media (max-width: 640px) {
  .title {
    font-size: 1rem;
  }
}
</style>

</BaseLayout>
