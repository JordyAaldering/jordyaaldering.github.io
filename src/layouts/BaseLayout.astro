---
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title}</title>
    <style>
      :root {
        --text-color: #1F2933;
        --link-color: #1F2933;
      }

      .site-nav {
        display: flex;
        justify-content: center;
        border-bottom: 1px solid #A9A9A9;
        padding: 1.2rem;
        gap: 2.2rem;
      }
      .site-nav a {
        color: #1F2933;
        font-weight: bold;
        text-decoration: none;
        transition: color 0.2s ease;
      }
      .site-nav a:hover {
        color: #3DA542;
      }
      @media (max-width: 640px) {
        .site-nav {
          gap: 1rem;
          font-size: 0.95rem;
          flex-wrap: wrap;
        }
      }

      body {
        min-height: 100vh;
        background-image: url('/background.svg');
        background-repeat: no-repeat;
        background-position: center;
        background-size: cover;
        font-family: system-ui;
        font-size: clamp(16px, 1rem + 0.2vw, 18px);
        margin: clamp(12px, 4vw, 40px) auto;
        padding: 0 1rem;
        max-width: 75ch;
        line-height: 1.7;
      }
    </style>
  </head>

  <body>
    <nav class="site-nav">
      <a href="/">Home</a>
      <a href="/about/">About</a>
      <a href="/research/">Research</a>
      <a href="/teaching/">Teaching</a>
      <a href="/blog/">Blog</a>
    </nav>

    <main class="content">
      <slot />
    </main>
  </body>
</html>

<style>
.content {
  padding: 0rem 1.5rem;
  color: var(--text-color);
  overflow-wrap: break-word;
  hyphens: auto;
}
@media (min-width: 640px) {
  .content {
    text-align: justify;
    text-justify: inter-word;
  }
}

/* Links */
.content :where(a) {
  color: var(--link-color);
  text-decoration: none;
}
.content :where(a):hover {
  text-decoration: underline;
}

.content :where(h1,h2,h3) {
  line-height: 1.25;
  margin-top: 2rem;
  margin-bottom: 0.8rem;
}

.content :where(p,ul,ol) {
  margin-bottom: 1.2rem;
}

/* Images */
.content :where(img) {
  max-width: 100%;
  height: auto;
  border-radius: 6px;
}

/* Code */
.content :where(pre) {
  background: #F4F4F4;
  padding: 1rem;
  overflow-x: auto;
  border-radius: 6px;
}
.content :where(code) {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
}
</style>
