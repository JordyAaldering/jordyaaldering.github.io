---
import Squircle from './Squircle.astro';

const { squircle, color = "#3DA542" } = Astro.props;
---

<li class="timeline-item">
  <div class="timeline-inline">
    <Squircle text={squircle} color={color} />
    <div class="timeline-content">
      <slot />
    </div>
  </div>
</li>

<style>
.timeline-item {
  display: block;
}

.timeline-inline {
  display: flex;
  align-items: baseline;
  gap: 1rem;
}

.timeline-content {
  min-width: 0;
}

.timeline-item .timeline-content > *:first-child {
  margin-top: 0;
}

.timeline-item .timeline-content > :last-child {
  margin-bottom: 0;
}
</style>
