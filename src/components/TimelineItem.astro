---
import Squircle from './Squircle.astro';

const {
  text,
  date,
  width,
  color = '#3DA542',
} = Astro.props;
---

<li class="timeline-item">
  <div class="timeline-inline">
    <Squircle text={text} date={date} width={width} color={color} />
    <div class="timeline-content">
      <slot />
    </div>
  </div>
</li>

<style>
.timeline-item {
  display: block;
}

.timeline-inline {
  display: flex;
  align-items: baseline;
  gap: 1rem;
}

.timeline-content :global(p) {
  margin: 0;
}
</style>
