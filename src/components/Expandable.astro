---
interface Props {
  title: string
  open?: boolean
}

const { title, open = false } = Astro.props;
---

<details class="expandable" open={open}>
  <summary class="expandable-summary">
    <span class="expandable-title">{title}</span>

    <svg
      class="expandable-icon"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      width="18"
      height="18"
      aria-hidden="true"
    >
      <path
        d="M6 9l6 6 6-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </summary>

  <div class="expandable-content">
    <slot />
  </div>
</details>

<style>
.expandable {
  border: 1px solid var(--border-color, #e5e7eb);
  border-radius: 10px;
  background: var(--card-bg, #fafafa);
  margin: 1.5rem 0;
  overflow: hidden;
  transition: border-color 0.2s ease;
}

/* clickable header */

.expandable-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
  list-style: none;
  cursor: pointer;

  padding: 0.9rem 1rem;

  font-weight: 600;
  font-size: 0.95rem;

  user-select: none;
}

.expandable-summary::-webkit-details-marker {
  display: none;
}

.expandable-title {
  flex: 1;
}

/* arrow icon */

.expandable-icon {
  transition: transform 0.25s ease;
  opacity: 0.7;
}

details[open] .expandable-icon {
  transform: rotate(180deg);
}

/* content */

.expandable-content {
  padding: 0 1rem 1rem 1rem;
  color: #444;
  font-size: 0.95rem;
  line-height: 1.6;
}

/* spacing for markdown elements */

.expandable-content :global(p:first-child) {
  margin-top: 0.5rem;
}

.expandable-content :global(p:last-child) {
  margin-bottom: 0;
}

/* hover (desktop only) */

@media (hover: hover) {
  .expandable-summary:hover {
    background: rgba(0,0,0,0.03);
  }
}

/* mobile tweaks */

@media (max-width: 640px) {
  .expandable-summary {
    padding: 0.85rem 0.9rem;
    font-size: 0.9rem;
  }

  .expandable-content {
    padding: 0 0.9rem 0.9rem 0.9rem;
  }
}
</style>
