---
import { JSDOM } from 'jsdom';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  src,
  alt = "",
  style = "",
  frosted = true,
} = Astro.props;

if (!src) {
  throw new Error("Invalid SVG input");
}

// Parse SVG
const dom = new JSDOM(src, { contentType: "image/svg+xml" });
const document = dom.window.document;

// Apply translations
document.querySelectorAll('text, tspan').forEach(node => {
  const raw = node.textContent.trim();
  node.textContent = raw.replace(/t\((.*?)\)/g, (_, key) => t(key));
});

// Add accessibility + styling to root <svg>
const svgEl = document.querySelector('svg');

if (svgEl) {
  if (alt) svgEl.setAttribute('aria-label', alt);
  svgEl.setAttribute('role', 'img');
}

const output = document.documentElement.outerHTML;
---

<span style={style} class:list={["svg-wrapper", { "svg-wrapper-frosted": frosted }]}>
  <span class="svg-content" set:html={output} />
</span>

<style>
  .svg-wrapper {
    display: inline-block;
    vertical-align: middle;
    max-width: 100%;
    width: 100%;
    height: auto;
  }

  .svg-wrapper-frosted {
    padding: 0.75rem;
    border-radius: 0.75rem;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(1px);
  }

  .svg-content :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
