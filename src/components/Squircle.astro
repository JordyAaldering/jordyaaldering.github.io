---
const {
  text,
  date,
  width = '72px',
  height = 'normal',
  locale = 'en-gb',
  color = '#3DA542',
} = Astro.props;

const isDate = date !== undefined;

const dateFormatter = new Intl.DateTimeFormat(locale, {
  day: '2-digit',
  month: 'short',
  year: 'numeric'
});

const displayText = isDate
  ? (typeof date === 'string' ? date : dateFormatter.format(typeof date === 'number' ? new Date(date) : date))
  : text;
---

<div class:list={["squircle", { "squircle-date": isDate }]}>{displayText}</div>

<style>
.squircle {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  min-width: {width};
  height: {height};
  padding: 0 0.6rem;

  font-size: 0.8rem;
  font-weight: 600;

  color: white;
  background: #3DA542;

  border-radius: 12px;
  flex-shrink: 0;
  text-align: center;
  white-space: nowrap;
}

.squircle-date {
  font-family: var(--font-mono);
}
</style>
